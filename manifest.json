{
  "manifest_version": 3,
  "name": "Input Improve Helper",
  "description": "Adds a floating optimize button to text inputs and uses an OpenAI-compatible API to improve the text.",
  "version": "1.0.3",
  "permissions": [
    "storage"
  ],
  "optional_host_permissions": [
    "https://*/*",
    "http://*/*"
  ],
  "options_page": "dist/options.html",
  "background": {
    "service_worker": "dist/background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "dist/contentScriptMain.js"
      ],
      "run_at": "document_idle",
      "world": "MAIN"
    },
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "dist/contentScript.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "128": "icon128.png"
  }
}
